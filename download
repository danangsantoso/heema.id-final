// Heema - Supabase client
// Configured via Vercel env vars: VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY

import { createClient } from "@supabase/supabase-js";

const SUPABASE_URL = import.meta.env.VITE_SUPABASE_URL || "https://vcvgndpqntofbhurxkcb.supabase.co";
const SUPABASE_ANON_KEY = import.meta.env.VITE_SUPABASE_ANON_KEY || "sb_publishable_HO_K6pNvK5GOGreppZ7nig_9k-PsRGt";

export const supabase = createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
  auth: {
    persistSession: true,
    autoRefreshToken: true,
    detectSessionInUrl: true,
    flowType: "pkce",
  },
});

// Helper: Sign in with Google OAuth
export const signInWithGoogle = async (redirectTo) => {
  const { data, error } = await supabase.auth.signInWithOAuth({
    provider: "google",
    options: {
      redirectTo: redirectTo || window.location.origin,
      queryParams: {
        access_type: "offline",
        prompt: "consent",
      },
    },
  });
  if (error) throw error;
  return data;
};

// Helper: Sign in with email/password
export const signInWithEmail = async (email, password) => {
  const { data, error } = await supabase.auth.signInWithPassword({ email, password });
  if (error) throw error;
  return data;
};

// Helper: Sign up new user with email + password + role
export const signUpWithEmail = async (email, password, metadata = {}) => {
  const { data, error } = await supabase.auth.signUp({
    email, password,
    options: { data: metadata },
  });
  if (error) throw error;
  return data;
};

// Helper: Sign out
export const signOut = async () => {
  const { error } = await supabase.auth.signOut();
  if (error) throw error;
};

// Helper: Get current user
export const getCurrentUser = async () => {
  const { data: { user } } = await supabase.auth.getUser();
  return user;
};

// Helper: Get user profile with role
export const getUserProfile = async (userId) => {
  const { data, error } = await supabase
    .from("profiles")
    .select("*")
    .eq("id", userId)
    .single();
  if (error) return null;
  return data;
};

// Helper: Upload file to storage bucket
export const uploadFile = async (bucket, path, file) => {
  const { data, error } = await supabase.storage
    .from(bucket)
    .upload(path, file, { upsert: true });
  if (error) throw error;
  const { data: { publicUrl } } = supabase.storage.from(bucket).getPublicUrl(path);
  return publicUrl;
};

// Helper: Get public URL for a file
export const getPublicUrl = (bucket, path) => {
  const { data } = supabase.storage.from(bucket).getPublicUrl(path);
  return data.publicUrl;
};

// Helper: Confirm a public donation (calls Postgres function)
export const confirmDonasiPublik = async (donasiId) => {
  const { data, error } = await supabase.rpc("confirm_donasi_publik", {
    donasi_uuid: donasiId,
  });
  if (error) throw error;
  return data;
};

// Helper: Get masjid statistics
export const getMasjidStats = async (masjidId) => {
  const { data, error } = await supabase.rpc("get_masjid_stats", {
    masjid_uuid: masjidId,
  });
  if (error) throw error;
  return data;
};
